# Resend: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Başvuru bildiriminin gideceği e-posta
MEMBERSHIP_NOTIFY_EMAIL=sihamed.dhmi@gmail.com

# Gönderen (Resend'de doğrulanmış alan adı kullanın; test için onboarding@resend.dev)
# RESEND_FROM_EMAIL=SİHAMED <bildirim@sihamed.org.tr>
RESEND_FROM_EMAIL=SİHAMED Başvuru <onboarding@resend.dev>

# Admin paneli ( /admin )
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong-password
ADMIN_SESSION_SECRET=change-this-long-random-secret

# Üye sayısını PostgreSQL'de saklama
# Docker ile varsayılan bağlantı:
# DATABASE_URL=postgresql://admin:admin123@postgres-db:5432/sihamed2
DATABASE_URL=postgresql://admin:admin123@localhost:5432/sihamed2

# Bazı ortamlarda SSL zorunlu olabilir (örn: cloud postgres)
# DATABASE_SSL=true
